{
  "name": "emblem-vault-sdk",
  "version": "2.10.0",
  "description": "Emblem Vault Software Development Kit",
  "main": "dist/index.js",
  "scripts": {
    "bump:major": "node ./script/bump.js major",
    "bump:minor": "node ./script/bump.js minor",
    "bump:patch": "node ./script/bump.js patch",
    "test": "npm run build && jest",
    "test:node": "JEST_ENV=node jest",
    "test:browser": "JEST_ENV=browser jest",
    "test:all": "npm run test:node && npm run test:browser",
    "build": "tsc",
    "postbuild": "node ./script/version.js && mv dist/index.d.ts types/index.d.ts && mv dist/types.d.ts types/types.d.ts && mv dist/utils.d.ts types/utils.d.ts && mv dist/derive.d.ts types/derive.d.ts && mv dist/constants.d.ts types/constants.d.ts && mv dist/evm-operations.d.ts types/evm-operations.d.ts && mv dist/signing-messages.d.ts types/signing-messages.d.ts && mv dist/vault-utils.d.ts types/vault-utils.d.ts",
    "bundle": "npm run build && browserify dist/index.js -o dist/bundle.js && cp dist/bundle.js docs/bundle.js",
    "watch": "onchange 'src/*.ts' -- npm run bundle"
  },
  "types": "types/index.d.ts",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/crypto-js": "4.2.2",
    "@types/jest": "29.5.14",
    "browserify": "17.0.1",
    "esmify": "2.1.1",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-puppeteer": "9.0.2",
    "puppeteer": "21.11.0",
    "ts-jest": "29.4.9",
    "tsify": "5.0.4",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@bitcoin-js/tiny-secp256k1-asmjs": "2.2.4",
    "@ethersproject/bignumber": "5.8.0",
    "@toruslabs/fetch-node-details": "8.1.1",
    "@toruslabs/torus.js": "6.4.1",
    "bchaddrjs": "0.5.2",
    "bip32": "4.0.0",
    "bip39": "3.1.0",
    "bitcoinjs-lib": "6.1.7",
    "bitcore-mnemonic": "10.10.7",
    "crypto-js": "4.2.0",
    "ethereumjs-util": "7.1.5",
    "ethers": "5.8.0",
    "install": "0.13.0",
    "npm": "10.9.8",
    "sats-connect": "1.4.1",
    "tiny-secp256k1": "2.2.4",
    "uninstall": "0.0.0",
    "web3": "4.16.0"
  },
  "engines": {
    "node": ">=20.5.1"
  }
}
